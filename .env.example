# ===== Chek_NVR cấu hình =====
# Copy file này thành .env và điền giá trị thật. KHÔNG commit .env.

# --- Database (PostgreSQL, async driver asyncpg) ---
DATABASE_URL=postgresql+asyncpg://chek_nvr:password@localhost:5432/chek_nvr

# --- Mã hóa mật khẩu NVR ---
# Tạo khóa Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Đăng nhập dashboard ---
# Bí mật ký cookie phiên. Để trống sẽ dùng tạm ENCRYPTION_KEY (nên đặt riêng).
# Tạo nhanh: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
SESSION_TTL_HOURS=12           # thời hạn phiên đăng nhập (giờ)
AUTH_ENABLED=true              # false để tắt yêu cầu đăng nhập (chỉ dùng khi dev)
COOKIE_SECURE=false            # true khi chạy sau HTTPS; false nếu truy cập qua HTTP thuần

# --- Tần suất quét (giây) ---
NVR_CHECK_INTERVAL=180          # quét NVR online/offline mỗi 3 phút
CAMERA_CHECK_INTERVAL=600       # quét camera mỗi 10 phút

# --- Tham số kiểm tra ---
REQUEST_TIMEOUT=10              # timeout mỗi request ISAPI (giây)
MAX_CONCURRENCY=20             # số NVR quét song song tối đa
FAIL_THRESHOLD=3               # số lần thất bại liên tiếp trước khi đánh Offline

# --- Ngưỡng cảnh báo ---
SLOW_RESPONSE_MS=5000          # phản hồi chậm hơn -> Warning/alert
CAMERA_OFFLINE_ALERT_MIN=10    # camera offline quá X phút -> alert

# --- Retention log (ngày) ---
LOG_RETENTION_DAYS=90

# --- App ---
TIMEZONE=Asia/Ho_Chi_Minh
DEBUG=true
ECHO_SQL=false                  # true để in câu lệnh SQL (chỉ khi cần debug DB)
