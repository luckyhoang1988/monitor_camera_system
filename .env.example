# ===== Chek_NVR cấu hình =====
# Copy file này thành .env và điền giá trị thật. KHÔNG commit .env.

# --- Database (PostgreSQL, async driver asyncpg) ---
DATABASE_URL=postgresql+asyncpg://chek_nvr:password@localhost:5432/chek_nvr

# --- Mã hóa mật khẩu NVR ---
# Tạo khóa Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Đăng nhập dashboard ---
# Bí mật ký cookie phiên. Để trống sẽ dùng tạm ENCRYPTION_KEY (nên đặt riêng).
# Tạo nhanh: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
SESSION_TTL_HOURS=12           # thời hạn phiên đăng nhập (giờ)
AUTH_ENABLED=true              # false để tắt yêu cầu đăng nhập (chỉ dùng khi dev)
COOKIE_SECURE=false            # true khi chạy sau HTTPS; false nếu truy cập qua HTTP thuần

# --- Tần suất quét (giây) ---
NVR_CHECK_INTERVAL=180          # quét NVR online/offline mỗi 3 phút
CAMERA_CHECK_INTERVAL=600       # quét camera mỗi 10 phút

# --- Tham số kiểm tra ---
REQUEST_TIMEOUT=10              # timeout tổng (giây): dùng cho ping/port + fallback
MAX_CONCURRENCY=20             # số NVR quét song song tối đa
FAIL_THRESHOLD=3               # số lần thất bại liên tiếp trước khi đánh Offline

# Timeout chi tiết cho HTTP ISAPI (giây)
CONNECT_TIMEOUT=5
READ_TIMEOUT=10
WRITE_TIMEOUT=5

# Retry lỗi mạng tạm thời (connect/read timeout) — KHÔNG retry 401
REQUEST_RETRIES=2
RETRY_BACKOFF_BASE=0.5         # giây; backoff mũ + jitter

# --- Bảo mật kết nối NVR (TLS) ---
# NVR Hikvision thường dùng cert tự ký -> mặc định không verify CA.
# Khuyến nghị production: pin fingerprint per-NVR (cột tls_fingerprint) để chặn MITM.
# Lấy fingerprint: openssl s_client -connect HOST:443 </dev/null 2>/dev/null \
#   | openssl x509 -noout -fingerprint -sha256
NVR_TLS_VERIFY=false           # true để bật xác thực chứng chỉ TLS theo CA
NVR_CA_CERT_PATH=              # đường dẫn CA bundle nội bộ (nếu có) -> ưu tiên hơn cờ trên

# --- Ngưỡng cảnh báo ---
SLOW_RESPONSE_MS=5000          # phản hồi chậm hơn -> Warning/alert
CAMERA_OFFLINE_ALERT_MIN=10    # camera offline quá X phút -> alert

# --- Cảnh báo qua Telegram (kênh ngoài, tùy chọn) ---
TELEGRAM_ENABLED=false          # true để đẩy mỗi alert mới lên Telegram
TELEGRAM_BOT_TOKEN=             # token từ @BotFather, dạng 123456:ABC-DEF...
TELEGRAM_CHAT_ID=               # id chat/group/channel (group thường là số âm)

# --- Retention log (ngày) ---
LOG_RETENTION_DAYS=90

# --- App ---
TIMEZONE=Asia/Ho_Chi_Minh
DEBUG=true
ECHO_SQL=false                  # true để in câu lệnh SQL (chỉ khi cần debug DB)
