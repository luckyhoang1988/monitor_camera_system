# ===== Chek_NVR — cấu hình cho Docker Compose =====
# Trên server: cp .env.docker.example .env  rồi điền giá trị thật. KHÔNG commit .env.

# --- PostgreSQL (dùng bởi service 'db' VÀ app) ---
POSTGRES_USER=chek_nvr
POSTGRES_PASSWORD=doi_mat_khau_manh_o_day
POSTGRES_DB=chek_nvr

# --- App kết nối DB ---
# QUAN TRỌNG: host là 'db' (tên service trong compose), KHÔNG phải localhost.
# Phải khớp POSTGRES_USER/PASSWORD/DB ở trên.
DATABASE_URL=postgresql+asyncpg://chek_nvr:doi_mat_khau_manh_o_day@db:5432/chek_nvr

# --- Mã hóa mật khẩu NVR (Fernet) — BẮT BUỘC ---
# Tạo: docker run --rm python:3.14-slim python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- Đăng nhập dashboard ---
# Tạo: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
SESSION_TTL_HOURS=12
AUTH_ENABLED=true
# true khi có HTTPS (reverse proxy/TLS); false nếu truy cập HTTP thuần.
COOKIE_SECURE=false

# --- Tần suất quét (giây) ---
NVR_CHECK_INTERVAL=180
CAMERA_CHECK_INTERVAL=600

# --- Tham số kiểm tra ---
REQUEST_TIMEOUT=10
MAX_CONCURRENCY=20
FAIL_THRESHOLD=3

# Timeout chi tiết cho HTTP ISAPI (giây)
CONNECT_TIMEOUT=5
READ_TIMEOUT=10
WRITE_TIMEOUT=5

# Retry lỗi mạng tạm thời (connect/read timeout) — KHÔNG retry 401
REQUEST_RETRIES=2
RETRY_BACKOFF_BASE=0.5

# --- Bảo mật kết nối NVR (TLS) ---
# NVR Hikvision thường dùng cert tự ký -> mặc định không verify CA.
# Production: pin SHA-256 fingerprint per-NVR (cột tls_fingerprint) để chặn MITM.
# Lấy fingerprint: openssl s_client -connect HOST:443 </dev/null 2>/dev/null \
#   | openssl x509 -noout -fingerprint -sha256
NVR_TLS_VERIFY=false           # true để bật xác thực chứng chỉ TLS theo CA
NVR_CA_CERT_PATH=              # CA bundle nội bộ (nếu có) -> ưu tiên hơn cờ trên

# --- Ngưỡng cảnh báo ---
SLOW_RESPONSE_MS=5000
CAMERA_OFFLINE_ALERT_MIN=10

# --- Retention log (ngày) ---
LOG_RETENTION_DAYS=90

# --- App ---
TIMEZONE=Asia/Ho_Chi_Minh
DEBUG=false
ECHO_SQL=false
